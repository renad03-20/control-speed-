{
  "manifest_version": 3,
  "name": "Control Speed",
  "version": "1.0",
  "description": "Control the playback speed of any HTML5 video on the web, even on sites without built-in speed controls.",
  "icons": {
    "16": "icons/icon_playback-16.png",
    "32": "icons/icon_playback-32.png",
    "48": "icons/icon_playback-48.png",
    "128": "icons/icon_playback-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon_playback-16.png",
      "32": "icons/icon_playback-32.png"
    },
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": ["storage", "activeTab", "scripting"]
}